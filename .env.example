# Public site config (inlined into the client bundle at `next build`)
NEXT_PUBLIC_SITE_URL=https://www.medicareinspokane.com
NEXT_PUBLIC_SITE_ENV=development
# Optional: leave unset to disable Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Server-side Firebase / Firestore (used by the lead form API route)
FIREBASE_PROJECT_ID=your-firebase-project-id
